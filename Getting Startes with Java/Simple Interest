import java.util.* ;
class Solution {
	
	public static void main(String args[]) {
		
		Scanner s = new Scanner(System.in);
		int amount = s.nextInt();
		double interest = s.nextDouble();
		int time = s.nextInt();
        int simint= (int) (amount * interest * time)/100;
		System.out.println(simint);	
	}
}
