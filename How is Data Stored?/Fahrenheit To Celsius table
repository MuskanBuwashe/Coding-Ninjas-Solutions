

import java.util.Scanner;
public class Solution {


	public static void main(String[] args) {
		Scanner s = new Scanner(System.in);
		int S = s.nextInt();
		int E = s.nextInt();
		int W = s.nextInt();
		
        
		while(S<E){
			
			int celsius = ((S-32)*5)/9;
			System.out.print(S+" ");
		    System.out.println(celsius+" ");
			S = S + W;
		}
		

		
	}

}
